{
  "name": "superset-plugin-leaflet-wms",
  "version": "0.1.0",
  "description": "With this chart WMS layers can be added to a leaflet map. It is necessary that the dataset is based on a service.json containing columns name, url and layers.",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "esm/index.js",
  "files": [
    "esm",
    "lib"
  ],
  "private": true,
  "scripts": {
    "build": "npm run build-esm",
    "build-cjs": "babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir lib",
    "build-esm": "BABEL_OUTPUT=esm babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir esm",
    "dev": "BABEL_OUTPUT=esm babel src --extensions \".ts,.tsx,.js,.jsx\" --watch --copy-files --out-dir esm",
    "prebuild": "rimraf {lib,esm,tsconfig.tsbuildinfo}",
    "ts-types": "tsc --build",
    "test": "jest"
  },
  "author": "Peter Keller",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@react-leaflet/core": "1.0.2",
    "antd": "^4.10.3",
    "leaflet": "^1.7.1",
    "process": "^0.11.10",
    "prop-types": "^15.8.1",
    "react": "^16.13.1",
    "react-leaflet": "^3.1.0",
    "styled-components": "^6.1.13",
    "react-dom": "^16.13.1"
  },
  "peerDependencies": {
    "@superset-ui/chart-controls": "^1.5.0",
    "@superset-ui/core": "^1.5.0"
  },
  "devDependencies": {
    "@airbnb/config-babel": "^3.1.0",
    "@babel/cli": "*",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@types/jest": "^29.5.12",
    "babel-plugin-typescript-to-proptypes": "^2.1.0",
    "css-loader": "^7.1.2",
    "jest": "^29.7.0",
    "rimraf": "*",
    "style-loader": "^4.0.0",
    "typescript": "^5.5.3"
  }
}
