{
  "name": "superset-plugin-chart-leaflet",
  "version": "0.1.0",
  "description": "Superset charts visualizing geographic data using leaflet",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "esm/index.js",
  "files": [
    "esm",
    "lib"
  ],
  "private": true,
  "scripts": {
    "build": "npm run build-esm",
    "build-cjs": "babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir lib",
    "build-esm": "BABEL_OUTPUT=esm babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir esm",
    "dev": "BABEL_OUTPUT=esm babel src --extensions \".ts,.tsx,.js,.jsx\" --watch --copy-files --out-dir esm",
    "prebuild": "rimraf {lib,esm,tsconfig.tsbuildinfo}",
    "ts-types": "tsc --build",
    "test": "jest"
  },
  "author": "Peter Keller",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "antd": "^4.10.3",
    "chroma-js": "^2.4.2",
    "colormap": "^2.3.2",
    "leaflet": "^1.9.4",
    "mapbox-gl": "^3.3.0",
    "maplibre-gl": "^4.1.3",
    "process": "^0.11.10",
    "prop-types": "^15.8.1",
    "react": "18.3.1",
    "react-leaflet": "*",
    "react-map-gl": "*",
    "styled-components": "^6.1.13",
    "react-dom": "^16.13.1"
  },
  "peerDependencies": {
    "@superset-ui/chart-controls": "*",
    "@superset-ui/core": "*"
  },
  "devDependencies": {
    "@airbnb/config-babel": "^3.1.0",
    "@babel/cli": "*",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@types/jest": "^29.5.12",
    "babel-plugin-typescript-to-proptypes": "^2.1.0",
    "jest": "^29.7.0",
    "rimraf": "*",
    "typescript": "^5.5.3"
  }
}
